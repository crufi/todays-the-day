#!/bin/sh
# Git "smudge" filter (blob -> worktree) for classic Mac OS text.
#
# Config (see install.sh):
#   filter.maceol.smudge = tools/mac-forks/maceol-smudge
#
# Reverses maceol-clean: turns the stored LF-based text back into
# CR-only text in the working tree. See maceol-clean for the full
# rationale, including why LC_ALL=C is forced here.
export LC_ALL=C
exec tr '\n' '\r'

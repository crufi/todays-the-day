#!/bin/sh
# Git "clean" filter (worktree -> blob) for classic Mac OS text.
#
# Config (see install.sh):
#   filter.maceol.clean = tools/mac-forks/maceol-clean
#
# Classic Mac OS text files use a bare CR (0x0D) as their line
# separator -- no LF at all. Git's own line-ending machinery
# (core.autocrlf, text=auto, eol=...) only knows about LF and CRLF, so
# it can't help here, and neither GitHub's web viewer nor a normal git
# diff understands a lone CR as a line break: the file just renders as
# one giant line.
#
# This has no forks or races to worry about (unlike machex/macderez) --
# it's a plain stdin/stdout content transform, so it doesn't need %f
# at all. Convert CR -> LF here so the *stored* blob is ordinary,
# diffable, GitHub-renderable text; maceol-smudge converts back on
# checkout so the working copy still has the CR-only line endings a
# vintage IDE/toolchain expects.
exec tr '\r' '\n'
